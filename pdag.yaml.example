# PDAG configuration example.
# Copy to pdag.yaml and adjust values for your environment.

listen: ":8080"
max_body_size: 1048576  # 1 MiB
shutdown_wait: 30s

# Trusted reverse-proxy CIDRs. When PDAG runs behind nginx/caddy, set this so the
# real client IP is taken from X-Forwarded-For (rightmost untrusted hop) for the
# per-key allowed_cidrs check and the audit log source_ip. Leave empty to use the
# immediate peer (r.RemoteAddr); X-Forwarded-For is then ignored (unspoofable).
# trusted_proxies:
#   - "10.0.0.0/8"
#   - "127.0.0.1/32"

upstreams:
  backends:
    - url: "http://pdns:8081"
      api_key: "pdns-internal-api-key"
      # api_key_file: "/run/secrets/upstream_api_key"  # alternative: read from file
    # - url: "http://pdns-2:8081"
    #   api_key: "pdns-internal-api-key"
  health_check:
    interval: 10s    # active health check interval (used with multiple backends)
    timeout: 2s      # health check request timeout
    path: "/api/v1/servers"  # health check endpoint

audit_log: "/var/log/pdag/audit.jsonl"
# audit_buffer_size: 4096          # in-memory audit entry buffer (channel) capacity
# audit_enqueue_timeout: 250ms     # how long to wait for buffer space before dropping (default mode)
                                   # or rejecting (fail-closed mode); 0 = non-blocking
# audit_fail_closed: false         # when true, reject requests with 503 if the audit pipeline is
                                   # saturated, so no audited action is forwarded upstream without a
                                   # durable audit record. Trades availability for audit completeness:
                                   # a sustained audit-write outage will start returning 503s.
# audit_log_body: false            # embed the request body in audit entries (off by default)
# audit_body_max_bytes: 8192       # cap logged body size (0 = unlimited); larger bodies are truncated
# audit_redact_fields:             # JSON field names whose values are redacted before logging
#   - "privatekey"
#   - "key"
#   - "secret"
#   - "tsig"

admin_token: "change-me-in-production"
# admin_token_file: "/run/secrets/admin_token"  # alternative: read from file

# Background purge of expired keys. 0 (default) disables it — operators call
# DELETE /admin/keys/expired on their own schedule. Set a positive duration to
# run an in-process cleanup goroutine.
# key_cleanup_interval: 0

# Restrict the real client IP (for per-key allowed_cidrs and the audit source_ip)
# when running behind a reverse proxy. When the peer is one of these CIDRs, the
# client IP is taken from X-Forwarded-For; otherwise XFF is ignored (unspoofable).
# trusted_proxies:
#   - "10.0.0.0/8"

metrics:
  listen: ":9090"

admin:
  listen: ":9091"

db:
  driver: "postgres"
  dsn: "postgres://pdag:pdag-secret@pdag-db:5432/pdag?sslmode=disable"

hmac_secrets:
  - id: "v1"
    secret: "change-me-in-production"
    # secret_file: "/run/secrets/hmac_v1"  # alternative: read from file

rate_limit:
  enabled: false         # set to true to enable per-principal rate limiting
  rate: 100              # requests per second per principal
  burst: 200             # max burst size per principal

tracing:
  enabled: false          # set to true to enable OpenTelemetry tracing
  endpoint: "localhost:4317"  # OTLP gRPC collector endpoint
  insecure: true          # use insecure gRPC connection (set false for TLS)
  sample_rate: 1.0        # 0.0 (none) to 1.0 (all requests)

plugin_defaults:
  timeout: 500ms
  circuit_breaker:
    failure_threshold: 5
    success_threshold: 2
    cooldown: 30s

plugins:
  admin:
    path: "/opt/pdag/plugins/admin"
    # sha256: "<64-hex-digest>"  # optional: pin the plugin binary; startup fails on mismatch
  read_zones:
    path: "/opt/pdag/plugins/read_zones"
  letsencrypt_dns_challenger:
    path: "/opt/pdag/plugins/letsencrypt_dns_challenger"
    timeout: 2s  # DNS resolution may be slow
    circuit_breaker:
      failure_threshold: 3
      cooldown: 60s
  zone_notify:
    path: "/opt/pdag/plugins/zone_notify"
  api_discovery:
    path: "/opt/pdag/plugins/api_discovery"
